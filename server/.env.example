# ============================================
# CM Media 统一配置文件（server）
# ============================================

# ---- 数据库 ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cm-media_2026
DB_USER=root
DB_PASSWORD=
DATABASE_URL="mysql://root:@127.0.0.1:3306/cm-media_2026"

# ---- Redis ----
REDIS_URL=redis://127.0.0.1:6379/0

# ---- JWT认证 ----
JWT_SECRET=
JWT_EXPIRES_IN=2h

# ---- 服务端口 ----
SERVER_PORT=4800
CLIENT_PORT=4900

# ---- 客户端URL（CORS用） ----
CLIENT_URL=http://localhost:4900
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4900

# ---- 安全策略 ----
MAX_LOGIN_ATTEMPTS=10

# ---- 分页 ----
PAGE_SIZE=20

# ---- CDN鉴权 ----
CDN_AUTH_KEY=

# ---- 阿里云VOD ----
ALIYUN_VOD_ACCESS_KEY=
ALIYUN_VOD_ACCESS_SECRET=
ALIYUN_VOD_ENDPOINT=vod.cn-beijing.aliyuncs.com
ALIYUN_ACCOUNT_ID=

# ---- 阿里云OSS ----
ALIYUN_OSS_ACCESS_KEY=
ALIYUN_OSS_ACCESS_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_CNAME=

# ---- 阿里云短信（登录告警） ----
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_ADMIN_PHONE=

# ---- 邮件SMTP（登录通知） ----
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_ADMIN_EMAIL=

# ---- 登录通知开关 ----
NOTIFY_ON_LOGIN=true
NOTIFY_ON_BRUTE_FORCE=true

# ---- 阿里云短信（短信验证码） ----
SMS_VERIFY_TEMPLATE_CODE=

# ---- 腾讯地图API（IP归属地查询） ----
QQ_MAP_API_KEY=

# ---- Cookie跨子域共享（API与前端不同子域时设置，同域留空） ----
COOKIE_DOMAIN=